---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import { Image } from "astro:assets";
import hero from "../assets/CuteCottage_IMG_0556.jpg";
import Gallery from "../components/Gallery.astro";
---

<Layout>
  <!-- ── Hero ── -->
  <div class="hero relative overflow-hidden rounded-3xl mb-8 aspect-square md:aspect-auto md:h-screen md:rounded-none">
    <Image
      src={hero}
      alt="Freestanding cottage exterior"
      class="w-full h-full object-cover object-center"
      widths={[800, 1200, 1600]}
      sizes="(max-width: 768px) 100vw, 1200px"
    />
    <!-- gradient scrim -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>

    <!-- ── Open House Banner ── -->
    <div class="open-house-banner">
      <p class="oh-title">Open House!</p>
      <p class="oh-detail">This weekend &mdash; Sat 4/25, 9am&ndash;12pm &nbsp;&bull;&nbsp; <a href="mailto:mattosurf@gmail.com" class="oh-email">mattosurf@gmail.com</a> for more info</p>
    </div>

    <!-- overlay text -->
    <div class="absolute bottom-0 left-0 right-0 p-6 md:p-12 text-white" style="text-shadow: 0 1px 6px rgba(0,0,0,0.5);">
      <div class="flex flex-wrap items-center gap-2 mb-3">
        <span class="bg-white/20 backdrop-blur-sm border border-white/30 text-white text-xs font-semibold px-3 py-1 rounded-full">
          Available July 2026
        </span>
        <span class="bg-violet-500/90 backdrop-blur-sm text-white text-xs font-semibold px-3 py-1 rounded-full">
          All Utilities Included
        </span>
      </div>
      <h1 class="text-3xl md:text-5xl font-bold leading-tight tracking-tight mb-2 text-white">
        Private Cottage — All Utilities Paid
      </h1>
      <p class="text-white/80 text-sm md:text-lg">King St &nbsp;·&nbsp; Santa Cruz, CA 95060</p>
    </div>
  </div>

  <!-- ── Stats bar ── -->
  <div class="flex flex-wrap items-center justify-between gap-4 border border-stone-200 rounded-2xl px-6 py-4 mb-10 bg-white shadow-sm">
    <div class="flex flex-wrap gap-6 text-sm text-stone-500 divide-x divide-stone-200">
      <div class="pr-6">
        <span class="block text-2xl font-bold text-stone-900">$2,900</span>
        <span>per month</span>
      </div>
      <div class="px-6">
        <span class="block text-2xl font-bold text-stone-900">1</span>
        <span>bedroom</span>
      </div>
      <div class="px-6">
        <span class="block text-2xl font-bold text-stone-900">1</span>
        <span>bathroom</span>
      </div>
      <div class="px-6">
        <span class="block text-2xl font-bold text-stone-900">12</span>
        <span>month lease</span>
      </div>
    </div>
    <div class="flex flex-col sm:flex-row gap-3">
      <a
        href="tel:+18312752566"
        class="bg-violet-600 text-white text-sm font-semibold py-2.5 px-5 rounded-xl hover:bg-violet-700 transition-colors text-center"
      >
        Call (831) 275-2566
      </a>
      <a
        href="mailto:mattosurf@gmail.com"
        class="border border-stone-300 text-stone-700 text-sm font-semibold py-2.5 px-5 rounded-xl hover:border-violet-400 hover:text-violet-700 transition-colors text-center"
      >
        Send Email
      </a>
    </div>
  </div>

  <!-- ── Body ── -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-10 mb-16">

    <!-- Left: description -->
    <div class="lg:col-span-2 space-y-10">

      <section>
        <p class="text-lg leading-relaxed text-stone-700">
          A rare find in Santa Cruz — this freestanding, conforming ADU combines privacy, comfort, and an
          unbeatable location. No shared walls, your own fenced yard, and all utilities covered.
          Just move in and enjoy.
        </p>
        <a
          href="https://www.airbnb.com/rooms/42617658"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 mt-4 bg-pink-500 hover:bg-pink-600 transition-colors text-white font-semibold px-5 py-3 rounded-xl"
        >
          <span class="text-base">View on Airbnb →</span>
        </a>
      </section>

      <section>
        <h2 class="text-lg font-semibold mb-3 pb-2 border-b border-stone-200">The Space</h2>
        <p class="leading-relaxed text-stone-600">
          High ceilings and abundant natural light give this cottage an open, airy feel. The
          well-appointed kitchen features a full-size gas stove and range with microwave above,
          and the full-size bath includes a shower/tub combo. An in-unit stacked washer and dryer
          make day-to-day living easy. Available unfurnished or partially furnished — your choice.
        </p>
      </section>

      <section>
        <h2 class="text-lg font-semibold mb-3 pb-2 border-b border-stone-200">What's Included</h2>
        <p class="leading-relaxed text-stone-600">
          All utilities — gas, electric, water, and garbage — are covered by the landlord.
          No surprise bills, ever.
        </p>
        <div class="flex flex-wrap gap-2 mt-4">
          {["⚡ Electricity", "🔥 Gas", "💧 Water", "♨️ Heat", "🗑️ Garbage Pickup"].map(u => (
            <span class="bg-stone-100 text-stone-700 text-sm font-medium px-3 py-1.5 rounded-full">{u}</span>
          ))}
        </div>
      </section>

      <section>
        <h2 class="text-lg font-semibold mb-3 pb-2 border-b border-stone-200">The Location</h2>
        <p class="text-stone-600 mb-4 leading-relaxed">
          Set on a quiet, tree-lined, bike-friendly street — you're minutes from everything Santa
          Cruz has to offer.
        </p>
        <ul class="space-y-2.5 text-stone-700">
          {[
            ["1.0 mi", "to downtown Santa Cruz"],
            ["1.5 mi", "to Cowell's Beach"],
            ["Walking/biking", "to bus stops, cafés, restaurants & health food stores"],
            ["1.4 mi", "to UCSC"],
            ["Easy access", "to Highways 1 and 17"],
          ].map(([label, detail]) => (
            <li class="flex gap-3 items-baseline">
              <span class="text-violet-600 font-semibold text-sm whitespace-nowrap">{label}</span>
              <span class="text-stone-600 text-sm">{detail}</span>
            </li>
          ))}
        </ul>
        <div class="flex gap-3 mt-5 text-xl" title="Transportation options">
          <span title="Bus">🚌</span>
          <span title="Bicycle">🚴</span>
          <span title="Walking">🚶</span>
          <span title="Driving">🚗</span>
        </div>
      </section>

      <section>
        <h2 class="text-lg font-semibold mb-3 pb-2 border-b border-stone-200">Apply</h2>
        <p class="text-stone-600 text-sm mb-4">Download the rental application to get started.</p>
        <a
          href="/application.pdf"
          download
          class="inline-flex items-center gap-2 border border-stone-300 text-stone-700 text-sm font-semibold py-2.5 px-5 rounded-xl hover:border-violet-400 hover:text-violet-700 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a2 2 0 002 2h12a2 2 0 002-2v-1M12 12v6m0 0l-3-3m3 3l3-3M12 3v9" />
          </svg>
          Download Application
        </a>
      </section>

    </div>

    <!-- Right: sidebar cards -->
    <div class="space-y-5">

      <!-- Contact card -->
      <div class="border border-stone-200 rounded-2xl p-5 shadow-sm bg-white sticky top-6">
        <p class="text-sm text-stone-500 mb-1">Contact landlord</p>
        <p class="font-semibold text-stone-900 mb-1">Matthew O'Leary</p>
        <a
          href="https://linkedin.com/in/matt-oleary/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 text-xs text-blue-600 hover:text-blue-800 transition-colors mb-4"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
        <div class="space-y-3">
          <a
            href="tel:+18312752566"
            class="flex items-center gap-3 bg-violet-600 text-white text-sm font-semibold py-3 px-4 rounded-xl hover:bg-violet-700 transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            (831) 275-2566
          </a>
          <a
            href="mailto:mattosurf@gmail.com"
            class="flex items-center gap-3 border border-stone-300 text-stone-700 text-sm font-semibold py-3 px-4 rounded-xl hover:border-violet-400 hover:text-violet-700 transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            mattosurf@gmail.com
          </a>
        </div>
        <p class="text-xs text-stone-400 mt-4 text-center">This one won't last — reach out today.</p>
      </div>

      <!-- Property details -->
      <div class="border border-stone-200 rounded-2xl p-5 bg-white">
        <p class="text-sm font-semibold text-stone-900 mb-4">Property Details</p>
        <dl class="space-y-2.5 text-sm">
          {[
            ["Type", "Cottage (ADU)"],
            ["Rent", "$2,900 / month"],
            ["Utilities", "All included"],
            ["Lease", "12 months"],
            ["Available", "July 1, 2026"],
            ["Landlord Occupied", "No"],
          ].map(([label, value]) => (
            <div class="flex justify-between gap-2">
              <dt class="text-stone-400">{label}</dt>
              <dd class="font-medium text-stone-700 text-right">{value}</dd>
            </div>
          ))}
        </dl>
      </div>

      <!-- Amenities -->
      <div class="border border-stone-200 rounded-2xl p-5 bg-white">
        <p class="text-sm font-semibold text-stone-900 mb-4">Amenities</p>
        <ul class="grid grid-cols-2 gap-y-2.5 text-sm text-stone-600">
          {[
            "🚲 Bike Storage",
            "🌿 Outdoor Area",
            "📦 Storage",
            "🧊 Refrigerator",
            "🍳 Gas Stove",
            "📡 Microwave",
            "🫧 Washer",
            "💨 Dryer",
          ].map(a => <li>{a}</li>)}
        </ul>
      </div>

    </div>
  </div>

  <!-- ── Gallery ── -->
  <div class="mb-4">
    <h2 class="text-lg font-semibold mb-6 pb-2 border-b border-stone-200">Photos</h2>
    <Gallery />
  </div>

  <!-- ── Bottom CTA ── -->
  <div class="mt-16 mb-4 rounded-3xl bg-violet-600 text-white px-8 py-12 text-center">
    <h2 class="text-2xl font-bold mb-2">Ready to make it yours?</h2>
    <p class="text-violet-200 mb-8 max-w-md mx-auto">
      This freestanding cottage won't be on the market long. Get in touch today to schedule a showing.
    </p>
    <div class="flex flex-col sm:flex-row justify-center gap-4">
      <a
        href="tel:+18312752566"
        class="bg-white text-violet-700 font-semibold py-3 px-8 rounded-xl hover:bg-violet-50 transition-colors"
      >
        Call (831) 275-2566
      </a>
      <a
        href="mailto:mattosurf@gmail.com"
        class="border border-white/40 text-white font-semibold py-3 px-8 rounded-xl hover:bg-white/10 transition-colors"
      >
        Send Email
      </a>
    </div>
  </div>
</Layout>
<Footer />

<style>
  .open-house-banner {
    position: absolute;
    left: 0;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    background: #ff2d9b;
    padding: 1.1rem 2rem;
    text-align: center;
    z-index: 10;
    box-shadow: 0 4px 32px rgba(0,0,0,0.35);
  }

  .oh-title {
    font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Arial, sans-serif;
    font-size: clamp(2rem, 8vw, 4rem);
    font-weight: 900;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: #fff;
    margin: 0 0 0.15em;
    line-height: 1;
  }

  .oh-detail {
    font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Arial, sans-serif;
    font-size: clamp(0.85rem, 2.5vw, 1.15rem);
    font-weight: 600;
    color: rgba(255,255,255,0.92);
    margin: 0;
    letter-spacing: 0.01em;
  }

  .oh-email {
    color: #fff;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .oh-email:hover { opacity: 0.8; }
</style>
