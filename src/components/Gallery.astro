---
import CuteCottage from "../assets/CuteCottage_IMG_0556.jpg";
import IMG_3453 from "../assets/IMG_3453.jpg";
import IMG_3455 from "../assets/IMG_3455.jpg";
import IMG_3461 from "../assets/IMG_3461.jpg";
import IMG_3463 from "../assets/IMG_3463.jpg";
import IMG_3464 from "../assets/IMG_3464.jpg";
import IMG_3465 from "../assets/IMG_3465.jpg";
import IMG_3466 from "../assets/IMG_3466.jpg";
import IMG_3467 from "../assets/IMG_3467.jpg";
import IMG_6786 from "../assets/IMG_6786.jpg";
import IMG_6790 from "../assets/IMG_6790.jpg";
import IMG_6793 from "../assets/IMG_6793.jpg";
import IMG_6796 from "../assets/IMG_6796.jpg";

const images = [
  { src: CuteCottage, alt: "Cottage exterior" },
  { src: IMG_3453, alt: "Interior" },
  { src: IMG_3455, alt: "Interior" },
  { src: IMG_3461, alt: "Interior" },
  { src: IMG_3463, alt: "Interior" },
  { src: IMG_3464, alt: "Interior" },
  { src: IMG_3465, alt: "Interior" },
  { src: IMG_3466, alt: "Interior" },
  { src: IMG_3467, alt: "Interior" },
  { src: IMG_6786, alt: "Interior" },
  { src: IMG_6790, alt: "Interior" },
  { src: IMG_6793, alt: "Interior" },
  { src: IMG_6796, alt: "Interior" },
];
---

<!-- Mobile: horizontal scroll-snap carousel. Desktop: masonry grid. Click/tap: custom lightbox. -->
<div
  class="gallery-scroll flex overflow-x-auto snap-x snap-mandatory gap-3 pb-1 md:block md:columns-3 2xl:columns-4 md:overflow-visible"
  id="botanicalsGallery"
>
  {images.map((image, index) => (
    <div class="snap-start shrink-0 w-[78vw] md:w-auto md:break-inside-avoid md:mb-4 rounded-2xl overflow-hidden">
      <a
        href={image.src.src}
        data-src={image.src.src}
        data-alt={image.alt}
        class="block cursor-zoom-in"
      >
        <img
          class="block w-full aspect-[4/3] md:aspect-auto object-cover transition-transform duration-300 hover:scale-[1.03]"
          src={image.src.src}
          alt={image.alt}
          width={image.src.width}
          height={image.src.height}
          loading={index === 0 ? "eager" : "lazy"}
        />
      </a>
    </div>
  ))}
</div>

<style>
  .gallery-scroll::-webkit-scrollbar { display: none; }
  .gallery-scroll {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  @media (min-width: 768px) {
    .gallery-scroll { column-gap: 1rem; }
  }
</style>
